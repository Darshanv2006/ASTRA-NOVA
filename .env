# OpenRouter API - Nemotron Model
# Get your free key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# N2YO API Configuration (optional - used if BACKEND_URL not set)
# Get your free API key from: https://www.n2yo.com/
# Login → My Account → API Key
N2YO_API_KEY=YZ6VTY-NFE5A5-EQUQ3V-5P8C

# Observer location (your ground station position)
# Example: Bangalore, India
N2YO_OBSERVER_LAT=28.6139
N2YO_OBSERVER_LNG=77.2090
N2YO_OBSERVER_ALT=100

# Backend API URL - SET THIS TO USE YOUR SQLITE BACKEND
# The backend server runs on http://localhost:3002
VITE_BACKEND_URL=http://127.0.0.1:3002
